# Experiment outputs
# Track lightweight audit/report/result files so GitHub records what each run did.
# Heavy binary/cache outputs remain blocked by the binary patterns below.
outputs/**
!outputs/
!outputs/**/
!outputs/**/*.md
!outputs/**/*.csv
!outputs/**/*.json
!outputs/**/*.txt
!outputs/**/*.yaml
!outputs/**/*.yml

workbench/*/outputs/**
!workbench/*/outputs/
!workbench/*/outputs/**/
!workbench/*/outputs/**/*.md
!workbench/*/outputs/**/*.csv
!workbench/*/outputs/**/*.json
!workbench/*/outputs/**/*.txt
!workbench/*/outputs/**/*.yaml
!workbench/*/outputs/**/*.yml

sas_cert_mve_outputs/**
!sas_cert_mve_outputs/
!sas_cert_mve_outputs/**/
!sas_cert_mve_outputs/**/*.md
!sas_cert_mve_outputs/**/*.csv
!sas_cert_mve_outputs/**/*.json
!sas_cert_mve_outputs/**/*.txt

sas_cert_cbramod_mve/outputs/**
!sas_cert_cbramod_mve/outputs/
!sas_cert_cbramod_mve/outputs/**/
!sas_cert_cbramod_mve/outputs/**/*.md
!sas_cert_cbramod_mve/outputs/**/*.csv
!sas_cert_cbramod_mve/outputs/**/*.json
!sas_cert_cbramod_mve/outputs/**/*.txt

# Do not version vendored dependency snapshots inside output folders.
outputs/**/local_python_deps/**
outputs/**/python_target/**
workbench/*/outputs/**/local_python_deps/**
workbench/*/outputs/**/python_target/**
sas_cert_mve_outputs/**/local_python_deps/**
sas_cert_mve_outputs/**/python_target/**
sas_cert_cbramod_mve/outputs/**/local_python_deps/**
sas_cert_cbramod_mve/outputs/**/python_target/**

# External repositories and downloaded artifacts
third_party/**
**/third_party/**
artifacts/source_archives/**
!artifacts/
!artifacts/source_archives/
!artifacts/source_archives/README.md

# EEG/data/checkpoint binaries
*.edf
*.edf.event
*.mat
*.npy
*.npz
*.pt
*.pth
*.ckpt
*.lmdb
*.mdb
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
docs/references/*.pdf
paper/**/main.pdf

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.out
*.synctex.gz

# Runtime/cache files
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log

# Local envs
.venv/
venv/
env/
*.egg-info/

# Editor/OS
.DS_Store
.idea/
.vscode/

# GPU hold runtime logs are local state
显存占位/
显存占位/*.log

# Personal/local notes are not part of the public project upload
参考论文集/
复盘助手
选题.txt
github上传命令
